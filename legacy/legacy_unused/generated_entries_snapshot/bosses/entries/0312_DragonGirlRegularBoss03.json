    "passives": {
      "FireFocusPassiveADragonGirlRegularBoss": {
        "id": "FireFocusPassiveADragonGirlRegularBoss",
        "found": true,
        "localization": {
          "name": "Dragon's Focus",
          "description": "This unit cannot be defeated by damage from Burn status effects, and cannot be Stunned. If this unit is burning, this unit has Hold Ground (if this unit would be defeated by an enemy attack or a status effect while having more than 1 HP, it instead survives with 1 HP).\n\nAdd a Super Himori to the end of allied reinforcements whenever:\n- this unit defeats any number of enemies with an attack while on the battlefield.\n- a non-conjured Fire ally on the battlefield is defeated or sacrificed by any source.\n\nWhenever a Himori ally on the battlefield is defeated or sacrificed by any source (even if Ephemeral), a random burning enemy is Stunned for 100TU. Whenever an ally Himori enters the battlefield from reinforcements, stun a random enemy for 50TU."
        }
      },
      "DragonEntryADragonGirlRegularBoss": {
        "id": "DragonEntryADragonGirlRegularBoss",
        "found": true,
        "localization": {
          "name": "Fiery Thunder",
          "description": "This unit enters battle with the Healing Burn status effect for 300TU, and has 80% damage reduction from attacks until it damages an enemy with an attack while on the battlefield.\n\nStun a random burning enemy for 50TU. This effect triggers once for each burning unit on the battlefield when this unit enters the battlefield from allied reinforcements.\n\nA unit with Healing Burn will heal after each turn at the same rate as Burn deals damage. Healing Burn will overwrite other status effects on the user and can replace the Burn status effect, but cannot be replaced by Burn. Any unit that deals damage to or is dealt damage by a unit with Healing Burn will gain the Burn status effect. Healing Burn will not be removed by Purify skills."
        }
      },
