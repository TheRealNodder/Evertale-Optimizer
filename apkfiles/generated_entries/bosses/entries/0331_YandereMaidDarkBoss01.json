    "passives": {
      "PoisonLustPassiveAYandereMaidDarkBoss": {
        "id": "PoisonLustPassiveAYandereMaidDarkBoss",
        "found": true,
        "localization": {
          "name": "Poisonous Maid",
          "description": "If this unit would be defeated by an attack while there is a Poisoned enemy on the battlefield, this unit will survive with 1HP remaining instead. Then this unit will remove poison (including Lethal Poison) from a random poisoned enemy at the end of turn.\n\nThis unit's Attack is increased by:\n- 1.05x if there is exactly 1 Poisoned enemy on the battlefield.\n- 1.1x if there are exactly 2 Poisoned enemies on the battlefield.\n- 1.15x if there are exactly 3 Poisoned enemies on the battlefield.\n- 1.20x if there are exactly 4 Poisoned enemies on the battlefield.\nThese Attack increases do not stack with Enrage effects."
        }
      },
      "EvasionPassiveAYandereMaidDarkBoss": {
        "id": "EvasionPassiveAYandereMaidDarkBoss",
        "found": true,
        "localization": {
          "name": "Relentless Maid",
          "description": "This unit cannot be defeated by damage from Poison or Burn status effects.\n\nIf no enemy is Poisoned at the start of an enemy turn, then at the end of that turn this unit will be Purified (any negative status effects like sleep, burn or poison are removed), and will get the next turn by having its TU reduced to 0. Then this effect cannot trigger again until 100TU advances\n\nAfter entering battle, for 100TU, this unit:\n- Cannot be burned\n- Reduces the amount of any stun effects against this unit by 100TU.\n- Will ignore attacks that would damage exactly 2 targets (attacks that target All allies will not be ignored)."
        }
      }
