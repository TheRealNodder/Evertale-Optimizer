      "ForceSleepHighLowEntranceAndKnockbackImmunity": {
        "id": "ForceSleepHighLowEntranceAndKnockbackImmunity",
        "found": true,
        "localization": {
          "name": "Turning Tides",
          "description": "Sleeps the non-sleeping enemy with the highest current TU for 200TU, then Sleeps the non-sleeping enemy with the lowest current TU for 200TU, even if those targets have already slept while on the battlefield. This unit will immediately get the next turn by having its TU reduced to 0. These effects are triggered when this unit enters the battlefield from the allied reinforcements.\n\nUntil this unit has defeated an enemy with an attack while on the battlefield, or if this unit is conjured:\n-This unit has 50% damage reduction from attacks.\n-When this unit gets a turn, it heals 30% of its max HP.\n\nThis unit cannot be sent to the reinforcements from the battlefield."
        }
      },
      "SuperStealthReincarnationOtohime": {
        "id": "SuperStealthReincarnationOtohime",
        "found": true,
        "localization": {
          "name": "Deadly Revival",
          "description": "If this unit has defeated an enemy with an attack while on the battlefield, revive this unit to the very front of allied reinforcements with full HP when this unit is defeated by an enemy attack. The revived unit will be considered a conjured unit and cannot be revived again. Use limits on active skills will be reset for the revived unit. This is not a Revenge passive skill.\n\nIf this unit is conjured, its attacks will ignore any effects of non-boss enemies that would prevent the target from being defeated, until it defeats an enemy that isn't a Mori or Imposter with an attack.\n\nThis unit will ignore attacks that would damage exactly 2 targets (attacks that target All allies will not be ignored). If this unit gains the Stealth status effect, it will not be lost when ignoring attacks in this way."
        }
      },
