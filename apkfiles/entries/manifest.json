{
  "schemaVersion": 1,
  "mode": "replacement-prep",
  "description": "Manifest for the new entry-based data system. This does not replace the old data/ structure yet.",
  "basePath": "apkfiles/entries",
  "categories": {
    "characters": {
      "index": "characters/index.json",
      "entriesPath": "characters/entries",
      "required": true
    },
    "weapons": {
      "index": "weapons/index.json",
      "entriesPath": "weapons/entries",
      "required": true
    },
    "accessories": {
      "index": "accessories/index.json",
      "entriesPath": "accessories/entries",
      "required": true
    },
    "bosses": {
      "index": "bosses/index.json",
      "entriesPath": "bosses/entries",
      "required": true
    }
  },
  "resolvers": {
    "path": "resolvers",
    "required": false
  },
  "reports": {
    "path": "reports",
    "buildReport": "reports/build_report.json",
    "checkpoint": "reports/build_checkpoint.json",
    "validationReport": "reports/validation_report.json",
    "replacementPlan": "reports/replacement_plan.md"
  },
  "failSafeRules": {
    "loadIndexesFirst": true,
    "loadEntriesIndividually": true,
    "skipBrokenEntries": true,
    "logBrokenEntries": true,
    "doNotBlockWholeSiteOnSingleEntryFailure": true,
    "keepLegacyDataUntouchedUntilFinalSwitch": true
  },
  "replacementReadiness": {
    "structureBuilt": true,
    "validationRequiredBeforeSwitch": true,
    "oldDataFolderIsLegacyOnly": true,
    "readyForLiveReplacement": false
  }
}
