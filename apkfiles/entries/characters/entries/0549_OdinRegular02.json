      "BirdSwarmingOdin": {
        "id": "BirdSwarmingOdin",
        "found": true,
        "localization": {
          "name": "Eyes of Odin",
          "description": "Add a number of Winged Shades to random places in ally reinforcements equal to the number of Awakenings this unit has plus 1, up to 5 max when fully awakened. Triggered when this unit enters battle (whether at the start of battle or from reinforcements), so long as this unit is not conjured and there are at least 5 non-conjured units in the ally team (including reinforcements). The number of Winged Shades added by this effect will be doubled if there are at least 10 non-conjured units in the ally team, up to 10 max when fully awakened.\n\nIf this unit is not conjured, this unit cannot be sent to the reinforcements from the battlefield.\n\nEvery Winged Shade conjured by this unit will have its Level, Limit Breaks, Awakenings, Boosts, Potential, Mastery, Weapon, and Accessory match this unit."
        }
      },
      "BirdRegenerationOdin": {
        "id": "BirdRegenerationOdin",
        "found": true,
        "localization": {
          "name": "Supreme Will",
          "description": "If this unit would be defeated by an enemy attack or a status effect while having more than 1 HP, it instead survives with 1 HP.\n\nThis unit enters battle with a Sleep Ward.\n\nIf this unit is conjured, it immediately gets the turn by having its TU reduced to 0 whenever it enters the battlefield from reinforcements.\n\nWhenever an ally Winged Shade gets the turn or enters the battlefield, this unit will be healed for 50% of max HP, will wake up if it is Sleeping, and will gain a Sleep Ward.\n\n-Sleep Ward prevents Sleep from being applied once, then is removed. Sleep Wards cannot stack."
        }
      },
