      "NoWakingNonBurningKnockoutKaguyahime": {
        "id": "NoWakingNonBurningKnockoutKaguyahime",
        "found": true,
        "localization": {
          "name": "Lunar Knockout",
          "description": "This unit's attacks will not wake sleeping enemies.\n\nWhenever an enemy survives an attack from this unit with 25% or less of max HP they will be granted the Cursed Sleep status effect for 200TU unless this unit is Burning.\n\nWhenever this unit defeats any number of enemies with an attack, 1 random non-sleeping enemy is granted the Cursed Sleep status effect for 200TU.\n\nCursed Sleep will overwrite status effects other than Burn, cannot be overwritten by Poison, can be applied repeatedly to units that have already slept while on the battlefield, and will not end from damage caused by Dream Hunter type active skills."
        }
      },
      "ThornSleepEnchantmentKaguyahime": {
        "id": "ThornSleepEnchantmentKaguyahime",
        "found": true,
        "localization": {
          "name": "Lunar Curse",
          "description": "Grants a random enemy the Cursed Sleep status effect for 200TU. 20% chance plus 20% per Awakening (up to 100% chance if this unit has 4 Awakenings) to trigger after each enemy turn if no enemy is sleeping already.\n\nWhen this unit enters battle (whether at the start of battle or from reinforcements) it will Endure the next damage that would defeat it with 1HP.\n\nWhenever a Sleeping enemy gets a turn, this unit heals 50% of its max HP and will again Endure the next damage that would defeat it with 1HP. Endure effects cannot stack.\n\nReduces the amount of any stun effects against this unit by 50TU."
        }
      },
