      "BadFriendSubstitute": {
        "id": "BadFriendSubstitute",
        "found": true,
        "localization": {
          "name": "Soul Substitute",
          "description": "While there is an Imposter among enemies on the battlefield:\n- This unit cannot be defeated by non-attack damage.\n- If this unit would be defeated by an attack while it does not have Endure, this unit will be Purified and healed for 100% of max HP, and then an enemy Imposter will be sacrificed.\n\nThis unit enters battle with a Poison Ward, Sleep Ward, Stun Ward, and Endure. Each Ward prevents their named effect from being applied once, then is removed. Identical Wards cannot stack.\n\nA unit with Endure will endure the next damage that would defeat it with 1HP. Endure effects cannot stack."
        }
      },
      "KillBadFriendMegaPoisonOthers": {
        "id": "KillBadFriendMegaPoisonOthers",
        "found": true,
        "localization": {
          "name": "Queen's Domain",
          "description": "The first damage this unit deals with an Attack while on the battlefield will ignore any effects of non-boss enemies that would prevent the target from being defeated.\n\nWhenever this unit defeats a non-conjured enemy with an attack, an Imposter is added to the next in line of enemy reinforcements.\n\nWhenever an enemy Imposter on the battlefield is defeated or sacrificed by any source (including Soul Substitute), all non-Imposter enemies on the battlefield that are not sleeping will become Mega Poisoned for 200TU and will be stunned for 50TU."
        }
      },
