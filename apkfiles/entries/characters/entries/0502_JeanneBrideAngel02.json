    "passives": {
      "ProtectUntilGetTurnEntrance": {
        "id": "ProtectUntilGetTurnEntrance",
        "found": true,
        "localization": {
          "name": "Angelic Guard Entry",
          "description": "This unit becomes a Guardian and cannot be defeated. These effects begin when this unit enters the battlefield from reinforcements and end after this unit's first turn on the battlefield. For any enemy attack that would hit 1 or 2 other allies while this unit is a Guardian, 1 of the hits is instead redirected to this unit. This unit will not redirect skills that don't deal damage. This unit cannot become a Stun Absorber while this skill is in effect."
        }
      },
      "StunHighestTUGrantPoisonImmuneBlockDeathOnceEntrance": {
        "id": "StunHighestTUGrantPoisonImmuneBlockDeathOnceEntrance",
        "found": true,
        "localization": {
          "name": "Angelic Shock Entry",
          "description": "Stuns the enemy with the highest current TU for 200TU. Storm allies named Jeanne d'Arc have any Poison removed, are granted a Poison Ward, and will Endure the next damage that would defeat them with 1HP. Endure effects cannot stack. These effects are triggered when this unit enters the battlefield from reinforcements. Poison Ward prevents Poison from being applied once, then is removed. Poison Wards cannot stack."
        }
      },
