        "found": true,
        "localization": {
          "name": "Ready To Serve",
          "description": "This unit cannot be sent to the reinforcements from the battlefield. This unit enters battle with a Poison Ward, Sleep Ward, and Stun Ward. Each Ward prevents their named effect from being applied once, then is removed. Identical Wards cannot stack.\n\nThis unit has 15% damage reduction from attacks, plus 15% per Awakening (up to 75% max if this unit has 4 Awakenings) until Survivor's Crash is unlocked.\n\nOnce Survivor's Crash is unlocked, this unit has its TU costs reduced by 40%. Quicken effects will not further reduce this unit's TU costs."
        }
      },
      "StunRodPassiveASnowWhiteMaid": {
