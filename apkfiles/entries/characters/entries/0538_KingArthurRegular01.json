    "passives": {
      "SuperBuffKingArthur": {
        "id": "SuperBuffKingArthur",
        "found": true,
        "localization": {
          "name": "King's Dawn",
          "description": "This unit's Attack is increased to 1.5x.\nThis unit's Active Skill TU Costs are reduced by 50%.\nThis unit has 50% damage reduction from attacks.\n\nAll of these effects are triggered when this unit begins on the battlefield at the very start of battle, and will end if this unit leaves the battlefield. This unit cannot be sent away from the battlefield during an ally turn.\n\n-This Attack increase does not stack with Enrage effects.\n-This will not reduce TU Costs to below 1TU.\n-Quicken effects will not further reduce this unit's TU costs."
        }
      },
      "HoldGroundPlusKillResetKingArthur": {
        "id": "HoldGroundPlusKillResetKingArthur",
        "found": true,
        "localization": {
          "name": "Cursed Hold Ground+",
          "description": "If this unit would be defeated, it instead survives with 1 HP and then cannot be defeated until its next turn. This effect ends after triggering once each time this unit enters the battlefield.\n\nWhenever this unit defeats an enemy with an attack or Regal Eclipse, this unit is healed for 100% of its max HP and this Hold Ground+ effect is reset so it can trigger again.\n\nWhenever a non-conjured enemy on the battlefield is defeated or sacrificed by any source, this unit gains 1 Charge. Certain skills are affected by and may consume charges. A unit can store a maximum of 3 charges, and all charges are removed from a unit that leaves the battlefield."
        }
      },
