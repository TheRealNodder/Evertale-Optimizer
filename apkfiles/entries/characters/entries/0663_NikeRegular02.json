    "passives": {
      "BladedWingsPassiveANikeRegular": {
        "id": "BladedWingsPassiveANikeRegular",
        "found": true,
        "localization": {
          "name": "Wings of Victory",
          "description": "If this unit would be defeated by an enemy attack or a status effect while having more than 1 HP, it instead survives with 1 HP.\n\nThis unit will ignore attacks that would damage exactly 2 targets (attacks that target All allies will not be ignored). If this unit gains the Stealth status effect, it will not be lost when ignoring attacks in this way.\n\nThis unit's attacks heal this unit for 100% of total damage dealt.\n\nWhenever this unit takes damage from an attack by an enemy unit that has defeated 0 units with attacks while on the battlefield, and survives until after the end of the turn, this unit will Purified (any negative status effects like sleep, burn or poison are removed), and will get the next turn by having its TU reduced to 0. This extra turn may be interrupted by other effects that influence the turn order (e.g. other stuns targeting the lowest TU target)."
        }
      },
      "VictoryChantPassiveANikeRegular": {
        "id": "VictoryChantPassiveANikeRegular",
        "found": true,
        "localization": {
          "name": "Victory Cry",
          "description": "This unit cannot fall asleep.\n\nWhen this unit enters battle, for 200TU, at the end of each turn an ally gets, the ally:\n- will heal for 10% of their max HP, plus 10% per Awakening Nike has (up to 50% if Nike has 4 Awakenings).\n- will have Sleep and Poison status effects other than Lethal Poison removed.\n- may gain a Sleep Ward, Stun Ward and a Poison Ward (50% chance for each ward).\nThis effect will end if this unit leaves the battlefield. Each Ward prevents their named effect from being applied once, then is removed. Identical Wards cannot stack.\n\nIf all allies on the battlefield are at max HP when this unit enters battle, this unit gains a Power Charge and Intense Rage. Otherwise, all allies are healed for 100% of their max HP, Purified, and may gain a Sleep Ward, Stun Ward, and a Poison Ward (50% chance for each ward).\n\nIntense Rage increases a units Attack to 1.5x for their next 3 turns, and will overwrite existing Weak or Enrage effects. It cannot be overwritten by other Enrage effects but can be by Weak effects."
        }
      },
      "PlusHPBoostLv3": {
        "id": "PlusHPBoostLv3",
        "found": true,
        "localization": {
          "name": "HP Up Lv3",
          "description": "Adds 1200 to this unit's max HP."
