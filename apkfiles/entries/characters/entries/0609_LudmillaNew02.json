    "passives": {
      "VanguardBarrierALudmillaNew": {
        "id": "VanguardBarrierALudmillaNew",
        "found": true,
        "localization": {
          "name": "Barrier of Light",
          "description": "When this unit enters the battlefield and at the end of each turn, if there is no ally Guardian on the battlefield, this unit will become a Stun Absorber (Whenever any ally would be affected by stun, this unit takes the stun instead). At end of each turn, if there is an ally Guardian on the battlefield, this unit will stop being a Stun Absorber.\n\nThis unit has 50% damage reduction from attacks, and is not affected by damage reduction effects granted by ally Barrier type skills.\n\nGrants all other allies 35% damage reduction from attacks while this unit is on the battlefield and there is no Guardian among allies. This effect does not stack with itself if another ally has this passive skill, or with other Barrier type skills.\n\nEach time this unit takes damage from an attack and survives until after the end of the turn, Weaken all enemies. If this unit survives until after the end of the turn with more than 1 HP, this unit will gain 1 Charge and heal 30% of max HP."
        }
      },
      "ChargeHoldGroundALudmillaNew": {
        "id": "ChargeHoldGroundALudmillaNew",
        "found": true,
        "localization": {
          "name": "Divine Intervention",
          "description": "If an acting enemy unit has had the turn 2 or more times already within the last 10TU, they are granted the Sleep status effect for 50TU at the end of their turn, even if they have already slept while on the battlefield.\n\nWhenever a non-conjured unit on the battlefield is defeated or sacrificed by any source, this unit will gain the Counter Stance status effect for 300TU.\n\nThis unit enters battle with 1 Charge. If this unit would be defeated while it has any charges, this unit will consume 1 charge to survive with 1HP remaining instead."
        }
      },
