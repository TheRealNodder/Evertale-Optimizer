    "passives": {
      "IcyBladePassiveAAnastasiaRegular": {
        "id": "IcyBladePassiveAAnastasiaRegular",
        "found": true,
        "localization": {
          "name": "Icy Princess",
          "description": "This unit's attacks will not wake sleeping enemies.\n\nWhenever this unit defeats any number of non-conjured enemies with an attack, an Imposter is added to the next in line of enemy reinforcements.\n\nEach time an ally with a Monarch token is damaged by an enemy attack (even if defeated), this unit will immediately have its TU reduced to 0.\n\nEach time this unit damages:\n- a non-sleeping enemy with an attack, a random ally has their current TU reduced by 10TU.\n- a sleeping, burning or frostburned enemy with an attack, this unit heals for 100% of max HP, and it will Endure the next damage that would defeat it with 1HP. Endure effects cannot stack."
        }
      },
      "ColdWindsPassiveAAnastasiaRegular": {
        "id": "ColdWindsPassiveAAnastasiaRegular",
        "found": true,
        "localization": {
          "name": "Cold Winds",
          "description": "This unit cannot be burned or poisoned.\n\nWhenever another Water or Fire ally enters the battlefield from reinforcements:\n- 2 random non-sleeping enemies are granted Frostburn.\n- 2 random non-burning allies on the battlefield are Purified (negative status effects like sleep or poison are removed).\n\nUntil the end of this unit's third turn while on the battlefield, this unit cannot be defeated by damage and heals for 25% of max HP at the end of every turn.\n\nAt the start of every turn while this unit is on the battlefield, if there is a sleeping, burning or frostburned unit on the battlefield:\n- this unit heals for 25% of max HP.\n- this unit will have its TU reduced to 0 at the end of the turn. This effect cannot trigger again until 50TU advances.\n- Allies gain 1 Spirit at the end of the turn."
        }
      },
