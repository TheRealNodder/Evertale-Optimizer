      "AutoProtectIfAllyStealthedAfterTurn": {
        "id": "AutoProtectIfAllyStealthedAfterTurn",
        "found": true,
        "localization": {
          "name": "Stealth Protect",
          "description": "This unit will gain Guard Once whenever another ally gains the Stealth status effect from an Active Skill during an ally turn. For the next enemy attack that would hit 1 or 2 other allies, 1 of the attacks is instead redirected to this unit. This unit will not redirect skills that don't deal damage. This effect will go away only if this unit redirects an attack, targeting this unit directly will not remove it. This unit cannot have the Counter Stance status effect while it has guard once."
        }
