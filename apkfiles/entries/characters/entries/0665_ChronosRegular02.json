    "passives": {
      "PrimordialPassiveAChronosRegular": {
        "id": "PrimordialPassiveAChronosRegular",
        "found": true,
        "localization": {
          "name": "Ruler of Time",
          "description": "This unit cannot fall asleep, be stunned or be sent to the reinforcements from the battlefield.\n\nAfter each ally and enemy turn, if this unit is on the battlefield and Time Stop is not active, there is a 25% chance for a random enemy to be Stunned for 25TU and a random ally to have its TU reduced by 25TU. This Stun cannot be redirected by enemy Stun Absorbers."
        }
      },
      "TemporalResistanceAChronosRegular": {
        "id": "TemporalResistanceAChronosRegular",
        "found": true,
        "localization": {
          "name": "Primordial Might",
          "description": "Each time a unit gets the turn, this unit will be healed for 30% of its max HP.\n\nIf this unit would be defeated, it instead survives with 1 HP and then cannot be defeated until its next turn. This effect can trigger once each time this unit enters the battlefield. Whenever an ally on the battlefield damages any number of units with 100TU or more with an attack, Allies gain 2 Spirit at the end of the turn. Then If Allies have 10 Spirit, this Hold Ground+ effect is reset so it can trigger again."
        }
      },
