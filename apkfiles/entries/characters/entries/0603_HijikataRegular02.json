    "passives": {
      "AllOutOffenseAHijikataRegular": {
        "id": "AllOutOffenseAHijikataRegular",
        "found": true,
        "localization": {
          "name": "Unwavering Demon",
          "description": "Poison cannot be applied to this unit while it has the Stealth status effect.\n\nThis unit will immediately get the next turn by having its TU reduced to 0. Triggered when this unit enters the battlefield from reinforcements unless there is a non-Mori Guardian among allies on the battlefield.\n\nUnless there is a non-Mori Guardian among allies on the battlefield, this unit has:\n- Attack increased to 1.5x. This effect does not stack with Enrage skills.\n- TU costs for all active skills reduced by 40%. This effect does not stack with Quicken skills."
        }
      },
      "HealStealthTurnRepriseAHijikataRegular": {
        "id": "HealStealthTurnRepriseAHijikataRegular",
        "found": true,
        "localization": {
          "name": "Demonic Resolve",
          "description": "Each time this unit takes damage from an attack while its TU is 100 or less and survives until after the end of the turn with more than 1 HP, this unit will immediately get the turn by having its TU reduced to 0. Then this unit will heal for 30% of max HP, and gain Stealth, even if it survived with 1HP. This extra turn may be interrupted by other effects that influence the turn order (e.g. stuns targeting the lowest TU target). This is not considered a Counter Skin type effect.\n\nThis unit enters battle with 3 Charges. If this unit would be defeated while it has any charges, this unit will consume 1 charge to survive with 1HP remaining instead. Whenever a Stealthed ally gets the turn, this unit gains 1 charge at the end of the turn. Certain skills are affected by and may consume charges. A unit can store a maximum of 3 charges, and all charges are removed from a unit that leaves the battlefield."
        }
      },
