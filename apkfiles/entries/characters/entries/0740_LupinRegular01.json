    "passives": {
      "MasterThiefPassiveALupinRegular": {
        "id": "MasterThiefPassiveALupinRegular",
        "found": true,
        "localization": {
          "name": "Phantom Thief",
          "description": "This unit cannot be poisoned or burned.\n\nWhenever an enemy on the battlefield is defeated or sacrificed by any source, this unit has a 20% chance, plus 20% chance per Awakening (up to 100% chance if this unit has 4 Awakenings) to immediately have its TU reduced to 0.\n\nEach time this unit takes damage from an attack and survives until after the end of the turn, this unit will be Purified, and heal for 25% of its max HP.\n\nThis unit has 35% damage reduction from attacks. This unit has 70% damage reduction from attacks instead if this unit has any Ward (e.g. an Instant Death Ward, Sleep Ward)."
        }
      },
      "EnteringTheBattlefieldPassiveALupinRegular": {
        "id": "EnteringTheBattlefieldPassiveALupinRegular",
        "found": true,
        "localization": {
          "name": "Planning Ahead",
          "description": "This unit cannot be sent to the reinforcements from the battlefield.\n\nIf this unit would be defeated by an enemy attack or a status effect while having more than 1 HP, it instead survives with 1 HP.\n\nThis unit enters battle with a Sleep Ward, Stun Ward, and an Instant Death Ward.\n\nThis unit gains the Super Stealth status effect, and a Stealth Shield. Triggered when this unit enters the battlefield from reinforcements.\n\nSuper Stealth will overwrite other Status effects. Super Stealthed units ignore enemy attacks that would damage more than 1 target. Super Stealth will be removed after ignoring 3 enemy attacks since applying, and can be overwritten by other status effects, except normal Stealth. Damage will not remove Super Stealth. Stealth Shields prevent the next non-stealth status effect a unit would gain while Stealthed from applying."
        }
      },
