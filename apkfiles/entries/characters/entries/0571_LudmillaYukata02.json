    "passives": {
      "GuardianEvasionLudmillaYukata": {
        "id": "GuardianEvasionLudmillaYukata",
        "found": true,
        "localization": {
          "name": "Evasive Guard",
          "description": "This unit has a 20% chance to ignore attacks that would damage exactly 2 targets, plus 20% per Awakening (up to 100% chance if this unit has 4 Awakenings). Attacks that target All allies will not be ignored. If this unit gains the Stealth status effect, it will not be lost when ignoring attacks in this way.\n\nThis unit is a Guardian. For any enemy attack that would hit 1 or 2 other allies, this unit has a 100% chance to redirect 1 hit to itself instead. This unit will not redirect skills that don't deal damage.\n\nThis unit cannot be sent to the reinforcements from the battlefield for 200TU after entering battle."
        }
      },
      "MegaHealArmorLudmillaYukata": {
        "id": "MegaHealArmorLudmillaYukata",
        "found": true,
        "localization": {
          "name": "Unrelenting Defense",
          "description": "The first time this unit takes damage from an attack and survives until after the end of the turn, this unit will enter Enduring Stance for 150TU. While in Enduring Stance, this unit cannot be defeated by damage unless it is burning, and cannot be granted Poison, Sleep, or Stuns.\nOnce Enduring Stance ends, this unit will enter Recovery Stance for 150TU. While in Recovery Stance, this unit has 65% damage reduction from attacks, and heals for 40% of max HP at the end of each turn. Whenever this unit is at max HP after this healing triggers, it will be Purified and will Endure the next damage that would defeat it with 1HP. Endure effects cannot stack. These stances can trigger once each time this unit is on the battlefield.\n\nWhen this unit enters battle all enemies will be granted Rage Wards. Rage Wards will prevent a unit from becoming Enraged once, then be removed. Rage Wards cannot stack."
        }
      },
