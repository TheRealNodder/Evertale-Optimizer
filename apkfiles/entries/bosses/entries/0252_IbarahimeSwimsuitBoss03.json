        "id": "SleepForceFieldIbarahimeSwimsuitBoss",
        "found": true,
        "localization": {
          "name": "Sleeping Beauty",
          "description": "Each time this unit takes damage from an attack and survives until after the end of the turn with more than 1HP, this unit grants a random non-sleeping enemy the Sleep status effect for 200TU, even if they have already slept while on the battlefield. This is not a Skin passive skill.\n\nAllies gain 1 Spirit each time a sleeping unit on the battlefield gets the turn.\n\nThis unit cannot be defeated by damage from Burn status effects."
        }
      },
      "UnkillableSleepIbarahimeSwimsuitBoss": {
        "id": "UnkillableSleepIbarahimeSwimsuitBoss",
        "found": true,
        "localization": {
          "name": "Dream Resistance",
          "description": "When another unit on the battlefield is sleeping, this unit gains 50% damage reduction from attacks and has a 100% chance to survive any attack that would defeat this unit with 1HP.\n\nEach time a sleeping ally gets the turn, they will have the TU costs for all of their skills reduced by 20%, and until the end of their next turn their Attack is increased to 1.5x. This will overwrite the effects of other Quicken, Weaken and Enrage skills on that ally."
        }
      },
