    "passives": {
      "HealingBurnHoldGroundEnergyChargedStart": {
        "id": "HealingBurnHoldGroundEnergyChargedStart",
        "found": true,
        "localization": {
          "name": "Face the Flames",
          "description": "This unit starts with the Healing Burn status effect for 300TU and 1 Charge, both at the very start of the battle if this unit is on the battlefield, and when this unit enters the battlefield from reinforcements.\n\nIf this unit would be defeated while it has any charges, this unit will consume 1 charge to survive with 1HP remaining instead. Other skills may also be affected by and may consume charges. A unit can store up to 3 charges."
        }
      },
      "RageBurnSpiritWhenMonstersDie": {
        "id": "RageBurnSpiritWhenMonstersDie",
        "found": true,
        "localization": {
          "name": "Viral Livestream",
          "description": "This unit gains the Healing Burn status effect for 300TU, is Enraged (its Attack is increased to 1.5x until the end of its next turn), and gains a Stun Ward. Allies gain 1 Spirit. All of these effects are triggered whenever another non-conjured unit (ally or enemy) on the battlefield is defeated or sacrificed by any source while this unit is not Sleeping. This may not trigger if this unit is defeated or sacrificed at the same time. This will overwrite other status effects and the effects of other Enrage skills on this unit. Healing Burn's duration will be reset if this unit already has it. Stun Wards cannot stack. Triggered effects on enemies that cause this unit to Sleep (e.g. Sleep Thorns) may prevent these effects from triggering."
        }
      },
      "KnockbackImmunity": {
        "id": "KnockbackImmunity",
        "found": true,
        "localization": {
          "name": "Immovable",
          "description": "This unit cannot be sent to the reinforcements from the battlefield."
        }
      }
