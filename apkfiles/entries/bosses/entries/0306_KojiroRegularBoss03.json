    "passives": {
      "HighToleranceAKojiroRegularBoss": {
        "id": "HighToleranceAKojiroRegularBoss",
        "found": true,
        "localization": {
          "name": "Great Resolve",
          "description": "This unit enters battle with a Poison Ward, Endure, and Counter Stance for 150TU. Counter Stance will overwrite status effects on this unit. The next time the unit with counter stance takes damage from an enemy attack, it will become their turn.\n\nThis unit has 80% damage reduction from attacks. This reduction is lowered by 10% for each enemy this unit has defeated with attacks while on the battlefield (to a minimum of 50% after defeating 3+ enemies).\n\nWhen this unit defeats any number of non-conjured enemies with an attack while on the battlefield:\n\n- this unit gains a Charge. Certain skills are affected by and may consume charges. A unit can store a maximum of 3 charges, and all charges are removed from a unit that leaves the battlefield.\n- all allies are Purified (negative status effects like sleep, burn or poison are removed).\n- another random ally is given the next turn by reducing their current TU to 0. Effects that influence TU order may interrupt the extra turn (e.g. Stuns targeting the lowest TU target)."
        }
      },
