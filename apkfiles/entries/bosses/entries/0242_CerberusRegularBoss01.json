    "passives": {
      "NoStunToughBurnGuardCerberusRegularBoss": {
        "id": "NoStunToughBurnGuardCerberusRegularBoss",
        "found": true,
        "localization": {
          "name": "Hell's Sentry",
          "description": "This unit is a Guardian so long as it has the burn status effect. While this unit is a Guardian, for any enemy attack that would hit 1 or 2 other allies, this unit has a 100% chance to redirect 1 hit to itself instead. This unit will not redirect skills that don't deal damage.\n\nThis unit has 40% damage reduction from attacks.\nThis unit is not affected by stun effects.\nBurns all units on the battlefield when this unit is defeated by an enemy, this will overwrite other status effects on those units."
        }
      },
      "HoldGroundGoodBurnCerberusRegularBoss": {
        "id": "HoldGroundGoodBurnCerberusRegularBoss",
        "found": true,
        "localization": {
          "name": "Heavy Defense",
          "description": "This unit enters battle with the Healing Burn status effect for 300TU.\n\nIf this unit takes damage from an attack and survives until after the end of the turn, this unit will:\n- Gain Healing Burn if it does not have Healing Burn, or a Sleep status effect (excluding Cursed or Noxious).\n- Heal for 5% of max HP.\nIf this unit isn't a Guardian, its Attack is increased to 1.25x and this unit will ignore attacks that would damage exactly 2 targets. Attacks that target All allies will not be ignored."
        }
      }
