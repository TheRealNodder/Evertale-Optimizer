    "passives": {
      "LightningPassiveAZeusRegularBoss": {
        "id": "LightningPassiveAZeusRegularBoss",
        "found": true,
        "localization": {
          "name": "Howling Thunder",
          "description": "This unit's attacks ignore Guardians.\n\nThis unit cannot be sent to the reinforcements from the battlefield.\n\nThis unit has Sleep immunity and Stun immunity. These immunity effects are removed from this unit when this unit activates Zeus's Whim.\n\nWhen this unit takes damage from an attack, they will immediately get the next turn, this cannot trigger again until TU advances. This is a skin effect. This unit cannot become a Guardian or Stun Absorber.\n\nThis unit enters battle with 3 Charges. Certain skills are affected by and may consume charges. A unit can store a maximum of 3 charges.\n\nAt the end of this unit's turn, if this unit has exactly:\n- 3 Charges, all enemies on the battlefield that have a current TU of 50 or less are stunned for 100TU.\n- 2 Charges, all enemies on the battlefield that have a current TU of 100 or less are stunned for 200TU.\n- 1 Charge, all enemies on the battlefield that have a current TU of 200 or less are stunned for 300TU.\nThen a Charge is consumed by this unit."
        }
      },
      "ChargedUpPassiveAZeusRegularBoss": {
        "id": "ChargedUpPassiveAZeusRegularBoss",
        "found": true,
        "localization": {
          "name": "Thunder God",
          "description": "If this unit would be defeated by an enemy attack or a status effect while having more than 1 HP, it instead survives with 1 HP.\n\nEach time an ally gets the turn, this unit will be healed for 1% of its max HP.\n\nAfter entering battle, this unit cannot be burned for 200TU.\n\nEach time this unit takes damage from an attack and survives until after the end of the turn, this unit will be Purified (any negative status effects like sleep, burn or poison are removed)."
        }
      }
