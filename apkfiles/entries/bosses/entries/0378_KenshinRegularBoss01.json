      "PoisonTurnPassiveAKenshinRegularBoss": {
        "id": "PoisonTurnPassiveAKenshinRegularBoss",
        "found": true,
        "localization": {
          "name": "Wild Swordsman",
          "description": "This unit cannot be sent to the reinforcements from the battlefield.\n\nIf this unit damages at least one poisoned enemy with an attack, this unit will get another turn. Damaged targets cannot trigger this effect again until TU advances. Effects that influence TU order may interrupt the extra turn (e.g. Stuns targeting the lowest TU target)."
        }
      },
      "HoldGroundPassiveAKenshinRegularBoss": {
        "id": "HoldGroundPassiveAKenshinRegularBoss",
        "found": true,
        "localization": {
          "name": "Keeper Of The Gate",
          "description": "This unit enters battle with Stealth, and a Stealth Shield.\n\nThis unit cannot be defeated by damage from Poison status effects.\n\nWhile there is a poisoned enemy on the battlefield, this unit has Stun Immunity.\n\nIf this unit would be defeated, it instead survives with 1 HP, then until its next turn:\n- this unit cannot be defeated.\n- this unit heals for 1% of max HP at the end of every turn.\nThis is a Hold Ground+ effect, and ends after triggering once each time this unit enters the battlefield."
        }
      }
