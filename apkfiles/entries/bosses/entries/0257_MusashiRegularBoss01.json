      "LowHpEnemyExtraTurnAMusashiRegularBoss": {
        "id": "LowHpEnemyExtraTurnAMusashiRegularBoss",
        "found": true,
        "localization": {
          "name": "Zero Mercy",
          "description": "Heals the user for 20% of total damage dealt.\n\nEach time this unit damages an enemy with an attack and leaves them on or below 25% of max HP (even if they are defeated by the attack), this unit will get another turn. The extra turn is granted after Counter Skin type effects triggered by this unit's attacks, and so this unit will act before a countering enemy.\n -This effect cannot trigger again against the same target until TU advances.\n -Effects that influence TU order may interrupt the extra turn (e.g. Stuns targeting the lowest TU target)."
        }
      }
