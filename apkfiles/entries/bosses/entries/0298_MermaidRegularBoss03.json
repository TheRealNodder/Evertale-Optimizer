    "passives": {
      "SleepSquadronPassiveAMermaidRegularBoss": {
        "id": "SleepSquadronPassiveAMermaidRegularBoss",
        "found": true,
        "localization": {
          "name": "Song of the Ocean",
          "description": "This unit's attacks will not wake sleeping enemies.\n\nAt the end of this unit's turn, send 1 random sleeping ally that is not immovable to the front of allied reinforcements. Allies must have reinforcements for this to trigger.\n\nWhenever another Water ally enters the battlefield from reinforcements:\n- Removes the Sleep status effect from this unit.\n- Grants 1 non-sleeping enemy with the lowest TU the Sleep status effect for 200TU, even if they have already slept while on the battlefield. This will overwrite other status effects on that unit."
        }
      },
      "ChannelTideBarrierAMermaidRegularBoss": {
        "id": "ChannelTideBarrierAMermaidRegularBoss",
        "found": true,
        "localization": {
          "name": "Breaking Current",
          "description": "Whenever this unit gets the turn, if all enemies are sleeping, the next damage this unit deals with an Attack while on the battlefield will ignore any effects of non-boss enemies that would prevent the targets from being defeated. This effect cannot trigger again until 100TU advances and cannot stack.\n\nWhen this unit enters battle, all allies will be granted Coral Barrier for 100TU. A unit with Coral Barrier will gain 35% damage reduction from attacks. This effect can stack with other damage reduction effects such as Armor, but will not stack with itself or other ally Barrier type skills.\n\nWhile this unit is on the battlefield, at the end of this unit or an ally Suimori's turn, all allies will:\n- Gain Coral Barrier for 100TU.\n- have Burn and Poison status effects (including Lethal Poison) removed."
        }
      },
