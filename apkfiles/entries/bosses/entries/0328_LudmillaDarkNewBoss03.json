    "passives": {
      "GuardPassiveALudmillaDarkNewBoss": {
        "id": "GuardPassiveALudmillaDarkNewBoss",
        "found": true,
        "localization": {
          "name": "Dark Guard",
          "description": "If this unit would be defeated, it instead survives with 1 HP and then cannot be defeated until its next turn. This effect can trigger only once each time this unit enters the battlefield, and is considered a Hold Ground+ effect.\n\nThis unit cannot be sent to the reinforcements from the battlefield. This unit has 50% damage reduction from attacks.\n\nThis unit will become a Guardian:\n- When this unit enters the battlefield, if there is no ally Guardian on the battlefield\n\nWhile this unit is a Guardian, for any enemy attack that would hit 1 or 2 other allies, this unit has a 100% chance to redirect 1 hit to itself instead. This unit will not redirect skills that don't deal damage.\n\nThis unit stops being a Guardian each time it activates Unleash Rage."
        }
      },
      "BladePassiveALudmillaDarkNewBoss": {
        "id": "BladePassiveALudmillaDarkNewBoss",
        "found": true,
        "localization": {
          "name": "Dark Marshal",
          "description": "This unit's attacks:\n- Ignore any effects of non-boss enemies that would prevent their targets from being defeated.\n- Weaken all enemies hit. This will overwrite any existing Weak or Enrage effects on those units.\n\nNew enemies entering the battlefield will be Weakened.\n\nIf this unit takes damage from an attack and survives until after the end of the turn, this unit will heal for 1% of max HP and be granted Stealth.\n\nStealth will overwrite other Status effects on this unit. Weakened units have their Attack reduced to 0.75x until the end of their next turn. The effect of Weakening may be diminished if the affected unit's Attack is increased by other effects and it can be overwritten by Enrage effects."
        }
      }
