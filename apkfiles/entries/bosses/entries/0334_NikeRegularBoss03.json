    "passives": {
      "BladedWingsPassiveANikeRegularBoss": {
        "id": "BladedWingsPassiveANikeRegularBoss",
        "found": true,
        "localization": {
          "name": "Blades of Victory",
          "description": "If this unit would be defeated by an enemy attack or a status effect while having more than 1 HP, it instead survives with 1 HP. This unit will ignore attacks that would damage exactly 2 targets (attacks that target All allies will not be ignored). If this unit gains the Stealth status effect, it will not be lost when ignoring attacks in this way.\n\nWhen this unit takes damage from an attack, they will immediately get the next turn. This cannot trigger again until TU advances. This unit cannot become a Guardian or Stun Absorber."
        }
      },
      "VictoryChantPassiveANikeRegularBoss": {
        "id": "VictoryChantPassiveANikeRegularBoss",
        "found": true,
        "localization": {
          "name": "Triumphant Cry",
          "description": "This unit cannot fall asleep.\n\nWhen this unit enters battle, for 200TU, at the end of each turn an ally gets, the ally:\n- will heal for 1% of their max HP.\n- will be Purified (any negative status effects like sleep, burn or poison are removed).\n- may gain a Sleep Ward, Stun Ward and a Poison Ward (50% chance for each ward).\nThis effect will end if this unit leaves the battlefield. Each Ward prevents their named effect from being applied once, then is removed. Identical Wards cannot stack.\n\nIf all allies on the battlefield are at max HP when this unit enters battle, this unit gains a Power Charge."
        }
      }
