    "passives": {
      "SometimesLuckyBuffAGenieRegularBoss": {
        "id": "SometimesLuckyBuffAGenieRegularBoss",
        "found": true,
        "localization": {
          "name": "Kind of Powerful?",
          "description": "This unit has a 33% chance to:\n\n- have its TU reduced to 0 after dealing damage with an Attack (1 chance per hit).\n- each turn, survive any damage that would defeat it with 1HP.\n- ignore the incoming status effects Poison, and Burn.\n- ignore attacks that would damage exactly 2 targets. Attacks that target All allies will not be ignored.\n- enrage 1 random ally at the end of each turn.\n- weaken 1 random enemy at the end of each turn.\n\nThe chance for each effect is determined independently each time they may occur. Enraged units have their Attack increased to 1.5x until the end of their next turn. Weakened units have their Attack reduced to 0.75x until the end of their next turn. These effects will overwrite any existing Weak or Enrage effects on affected units. The effect of Weakening may be diminished if the affected unit's Attack is increased by other effects and it can be overwritten by Enrage effects."
        }
      },
