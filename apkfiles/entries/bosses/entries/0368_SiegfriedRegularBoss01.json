    "passives": {
      "DragonHeartPassiveASiegfriedRegularBoss": {
        "id": "DragonHeartPassiveASiegfriedRegularBoss",
        "found": true,
        "localization": {
          "name": "Dragon's Bane",
          "description": "This unit cannot be defeated by damage from Burn status effects.\n\nThis unit cannot be sent to the reinforcements from the battlefield.\n\nUntil this unit defeats a non-conjured enemy with an attack while on the battlefield, this unit:\n- is immune to Sleep status effects.\n- is immune to Poison status effects.\n- has 50% damage reduction from attacks.\n\nThis unit enters battle with the Healing Burn status effect for 300TU and a Burn Shield.\n\nA unit with Healing Burn will heal after each turn at the same rate as Burn would deal damage instead of taking damage from Burn. Healing Burn will overwrite other status effects on the user and can replace the Burn status effect, but cannot be replaced by Burn. Any unit that deals damage to or is dealt damage by a unit with Healing Burn will gain the Burn status effect. Healing Burn will not be removed by Purify skills."
        }
      },
      "FafnirsBanePassiveASiegfriedRegularBoss": {
        "id": "FafnirsBanePassiveASiegfriedRegularBoss",
        "found": true,
        "localization": {
          "name": "Returning Hero",
          "description": "This unit enters battle with 1 Charge, 1% HP Regen for 100TU, and will Endure the first damage that would defeat it with 1HP. A unit with 1% HP Regen will heal for 1% of their max HP after every turn. HP Regen effects will overwrite existing HP Regen effects.\n\nThis unit cannot be stunned if there is a unit on the battlefield that is Fire element, or has a Burn Blast or Burn Drive type active skill.\n\nThis unit's active skills all cost 25% less TU for each charge it has stored, up to 75% less max with 3 charges. Other effects that further reduce TU will have diminishing returns while this is in effect.\n\nAt the end of each enemy turn, if no enemies had frostburn at the start of the turn, a random non-sleeping enemy is granted frostburn. This effect cannot trigger if Siegfried has no other allies on the battlefield."
        }
      }
    },
