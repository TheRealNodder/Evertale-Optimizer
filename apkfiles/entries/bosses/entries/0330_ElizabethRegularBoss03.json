    "passives": {
      "MonarchsWillAElizabethRegularBoss": {
        "id": "MonarchsWillAElizabethRegularBoss",
        "found": true,
        "localization": {
          "name": "Queen's Will",
          "description": "When an ally, including this unit enters the battlefield, all allies other than this unit receive a Monarch Token. Monarch Tokens cannot stack. Any attack damage will remove Monarch Tokens.\n\nEach time an ally with a Monarch token is damaged by an attack (even if defeated), this unit will immediately have its TU reduced to 0.\n\nTriggered when this unit enters the battlefield from the allied reinforcements:\n- Ally Spirit is doubled. If Ally Spirit is at 0, gain 1 Spirit instead.\n- Then remove burn (including Mega Healing Burn) from 1 random non-poisoned enemy and grant them Mega Poison for 200TU. This triggers an additional time for each 2 Spirit allies have (up to 5 additional times with 10 Spirit).\n- Then if all enemies are poisoned, all allies have their current TU reduced by 100TU.\n\nMega Poison will overwrite other status effects on those enemies. Mega Poison deals 20 times the damage of normal Poison and cannot be overwritten by normal Poison or Super Poison."
        }
      },
      "HoldGroundAElizabethRegularBoss": {
        "id": "HoldGroundAElizabethRegularBoss",
        "found": true,
        "localization": {
          "name": "The Queen",
          "description": "If this unit would be defeated by an enemy attack or a status effect while having more than 1 HP, it instead survives with 1 HP.\n\nThis unit has 50% damage reduction from attacks if allies have 6 or more Spirit.\n\nWhenever this unit damages any number of units with an attack, ally Spirit is doubled at the end of the turn, if ally Spirit is at 0, gain 1 Spirit instead. Then if allies have 10 Spirit, remove burn (including Mega Healing Burn) from 1 random non-poisoned enemy and grant them Mega Poison for 200TU.\n\nWhenever ally Spirit is at 10 at the end of any turn, all allies will be healed for 1% of max HP and be Purified (negative status effects like sleep, burn or poison are removed). This effect cannot trigger again until 100TU advances."
        }
      },
