    "passives": {
      "GuardianAngelPassiveAJeanneFusionBoss": {
        "id": "GuardianAngelPassiveAJeanneFusionBoss",
        "found": true,
        "localization": {
          "name": "Saint's Presence",
          "description": "This unit cannot fall asleep, or be stunned.\n\nThis unit enters battle with a Poison Ward, and a Burn Ward.\n\nTriggered when this unit enters the battlefield from the allied reinforcements:\n- Stuns 2 random enemies for 50TU.\n- Then disables 2 random enemies' Active Skills for 30TU.\nWhen a unit's Active Skills are disabled and they get the turn, they will lose the turn as if they were sleeping. This effect cannot affect boss units, cannot be purified, and will end if this unit is defeated.\n\nWhenever an ally \"Jeanne, The Saint of a Lost Kingdom\" enters the battlefield, this unit is purified."
        }
      },
      "LifeForALifePassiveAJeanneFusionBoss": {
        "id": "LifeForALifePassiveAJeanneFusionBoss",
        "found": true,
        "localization": {
          "name": "Unending Mercy",
          "description": "If this unit would be defeated, it instead survives with 1 HP and then cannot be defeated until its next turn. This effect can trigger only once each time this unit enters the battlefield, and is considered a Hold Ground+ effect. Whenever an ally named \"Jeanne, The Saint of a Lost Kingdom\" enters the battlefield, this Hold Ground+ effect is reset so it can trigger again.\n\nEach time this unit takes damage from an attack and survives until after the end of the turn, this unit will be Purified.\n\nAll Jeannes created by this unit will have matching Levels, Limit Breaks, Awakenings, Boosts, Potential, Mastery, Weapons, and Accessories.\n\nIf this unit is conjured, damage dealt to this unit is increased to 2.5 times the normal amount."
        }
      },
      "KnockbackImmunity": {
        "id": "KnockbackImmunity",
        "found": true,
        "localization": {
          "name": "Immovable",
          "description": "This unit cannot be sent to the reinforcements from the battlefield."
