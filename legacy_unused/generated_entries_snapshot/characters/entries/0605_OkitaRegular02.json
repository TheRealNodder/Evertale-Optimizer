    "passives": {
      "ChargedDefenseAOkitaRegular": {
        "id": "ChargedDefenseAOkitaRegular",
        "found": true,
        "localization": {
          "name": "Captain's Resolve",
          "description": "Unless this unit is burning, this unit is immune to Stun effects. Poison cannot be applied to this unit while it has the Stealth status effect. Until this unit has survived for 1000TU on the battlefield, this unit gains Stealth and a Stealth Shield every 100TU.\n\nThis unit's attacks heal this unit for 100% of total damage dealt. This unit enters battle with Stealth, a Stealth Shield, and 3 Charges. If this unit would be defeated while it has any charges, this unit will consume 1 charge to survive with 1HP remaining instead. Certain skills are affected by and may consume charges. A unit can store a maximum of 3 charges, and all charges are removed from a unit that leaves the battlefield."
        }
      },
      "KillerRevengeAOkitaRegular": {
        "id": "KillerRevengeAOkitaRegular",
        "found": true,
        "localization": {
          "name": "Vengeance Rampage",
          "description": "Whenever this unit defeats a non-conjured unit on the battlefield with an attack, the next damage this unit deals with an Attack while on the battlefield will ignore any effects of non-boss enemies that would prevent the target from being defeated.\n\nAllies gain the Stealth status effect, a Stealth Shield, 2 Spirit and will become Enraged. All of these effects are triggered whenever another non-conjured Ally on the battlefield is defeated or sacrificed by any source. This may not trigger if this unit is defeated or sacrificed at the same time. This will overwrite other status effects and the effects of other Enrage skills on those units. Enraged units have their Attack increased to 1.5x until the end of their next turn."
        }
      },
