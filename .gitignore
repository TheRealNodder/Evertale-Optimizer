node_modules/
npm-debug.log*
.DS_Store
__pycache__/
*.py[cod]
*.zip

scraper/node_modules/

# ignore everything in data by default
data/*

# allow committed JSON used by the site
!data/.gitkeep
!data/characters.json
!data/weapons.json
!data/accessories.json
!data/enemies.json
!data/bosses.json
!data/leader_skills.json
!data/catalog.items.json
!data/catalog.clean.json

# Legacy snapshots are not runtime data. Keep ordinary local archive material
# ignored, but track the bounded cleanup groups so GitHub receives moves rather
# than unexplained root-file deletions.
legacy/**
!legacy/CLEANUP_MANIFEST_2026-06-28.md
!legacy/workflows/
!legacy/workflows/**
!legacy/catalog-v1/
!legacy/catalog-v1/**
!legacy/catalog-tests/
!legacy/catalog-tests/retired-2026-06-28/
!legacy/catalog-tests/retired-2026-06-28/**
!legacy/runtime-unused/
!legacy/runtime-unused/**
!legacy/docs/
!legacy/docs/historical-root/
!legacy/docs/historical-root/**
!legacy/generated-stale/
!legacy/generated-stale/**
legacy/generated-stale/python-cache/
legacy/generated-stale/**/*.py[cod]

# APK/raw extraction extras that are not required by the live site.
apkfiles/newfiles.zip
apkfiles/il2cpp/
apkfiles/**/*.dat

# Local game save/account data must never be committed.
apkfiles/Saves/

# Master Control reports/markers should be artifacts, not permanent repo bloat.
apkfiles/entries/reports/*.json
apkfiles/entries/reports/*.md
apkfiles/entries/_markers/*.json

# Large localization diagnostics not loaded by the live site.
apkfiles/entries/localization/localizable_groups_by_category.json
apkfiles/entries/localization/localizable_group_report.json
